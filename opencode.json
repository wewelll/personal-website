{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "oxfmt": {
      "command": ["pnpm", "exec", "oxfmt", "$FILE"],
      "extensions": [".js", ".jsx", ".ts", ".tsx", ".css", ".mjs"]
    }
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": ["pnpm", "--silent", "dlx", "chrome-devtools-mcp@latest", "--no-usage-statistics"],
      "enabled": true
    }
  }
}
