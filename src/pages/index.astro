                        decoding="async"
                        class="relative h-9 w-auto opacity-95 transition duration-500 group-hover:scale-105 group-hover:opacity-100 sm:h-11"
                      />
                    </div>
                  ) : null
                }
                {
                  item.thumbnail ? (
                    <div class="relative -mx-2 -mt-2 mb-6 overflow-hidden rounded-[1.25rem] border border-white/10 bg-black/30">
                      <img
                        src={item.thumbnail}
                        alt={item.thumbnailAlt}
                        loading="eager"
                        decoding="async"
                        class="aspect-video w-full object-cover opacity-95 saturate-[0.9] transition duration-500 group-hover:scale-105 group-hover:opacity-100 group-hover:saturate-100"
                      />
                      <div class="absolute inset-0 bg-gradient-to-t from-black/45 via-black/5 to-transparent"></div>
                      <span class="absolute bottom-4 left-4 inline-flex items-center gap-2 rounded-full border border-white/15 bg-black/50 px-3 py-2 text-xs font-semibold text-white backdrop-blur">
                        <span class="flex size-6 items-center justify-center rounded-full bg-primary text-primary-foreground">
                          <svg aria-hidden="true" viewBox="0 0 16 16" class="ml-0.5 size-3 fill-current">
                            <path d="M4 2.75 12 8l-8 5.25v-10.5Z"></path>
                          </svg>
                        </span>
                        Watch on YouTube
                      </span>
                    </div>
                  ) : null
                }
                <span class="font-mono text-xs uppercase tracking-[0.25em] text-accent">{item.type}</span>
                <h3 class="mt-5 text-2xl font-black tracking-[-0.04em] text-white">{item.title}</h3>
                <p class="mt-4 text-sm leading-7 text-muted-foreground">{item.description}</p>
                <span class="mt-8 inline-flex text-sm font-semibold text-primary group-hover:underline">
                  Open link
                </span>
              </a>
            ))
          }
        </div>
      </section>

    </main>

    <footer class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-5 py-10 text-sm text-muted-foreground sm:px-8 md:flex-row md:items-center md:justify-between lg:px-10">
      <p>Samuel Briole</p>
      <div class="flex flex-wrap gap-4">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center gap-2 transition hover:text-primary"
              aria-label={link.label}
            >
              <svg aria-hidden="true" viewBox="0 0 24 24" class="size-4 fill-current">
                <path d={link.iconPath}></path>
              </svg>
              <span>{link.label}</span>
            </a>
          ))
        }
      </div>
    </footer>
  </div>
</Layout>
