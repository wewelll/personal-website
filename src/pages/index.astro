---
import Layout from "../layouts/Layout.astro";

const SPIKO_PUBLIC_API = "https://public-api.spiko.io/v0";

interface ShareClass {
  symbol: string;
  fundId: string;
  tokens?: Array<{
    network: string;
  }>;
}

interface ShareClassTotals {
  totalAssets: {
    value: string;
    currency: "EUR" | "USD" | "GBP" | "CHF" | "JPY" | "SGD";
  };
  totalOrders: {
    value: string;
    currency: "EUR" | "USD" | "GBP" | "CHF" | "JPY" | "SGD";
  };
  numberOfHolders: number;
  netAssetValue?: {
    updatedAt?: string;
  };
}

interface ExchangeRate {
  fxRate: string;
}

interface SpikoStats {
  assetsLabel: string;
  ordersLabel: string;
  networksDetail: string;
  updatedLabel: string;
  isLive: boolean;
}

const fallbackSpikoStats: SpikoStats = {
  assetsLabel: "EUR 1.5B+",
  ordersLabel: "EUR 5B+",
  networksDetail: "Ethereum, Polygon, Base, Arbitrum, Starknet, Stellar, Etherlink, Solana",
  updatedLabel: "public milestone",
  isLive: false,
};

const SPIKO_NETWORK_ORDER = [
  "Ethereum",
  "Polygon",
  "Base",
  "Arbitrum",
  "Starknet",
  "Stellar",
  "Etherlink",
  "Solana",
];

async function getJson<T>(url: string): Promise<T> {
  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 4_000);

  try {
    const response = await fetch(url, { signal: controller.signal });

    if (!response.ok) {
      throw new Error(`Spiko API returned ${response.status}`);
    }

    return (await response.json()) as T;
  } finally {
    clearTimeout(timeout);
  }
}

function formatLargeEurAmount(value: number) {
  if (value >= 1_000_000_000) {
    const roundedDown = Math.floor((value / 1_000_000_000) * 10) / 10;
    return `EUR ${roundedDown.toFixed(1)}B+`;
  }

  if (value >= 1_000_000) {
    const roundedDown = Math.floor(value / 100_000_000) * 100;
    return `EUR ${roundedDown}M+`;
  }

  return `EUR ${Math.floor(value).toLocaleString("en-US")}`;
}

function formatUpdatedAt(value: string | undefined) {
  if (!value) {
    return fallbackSpikoStats.updatedLabel;
  }

  return new Intl.DateTimeFormat("en-US", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(new Date(value));
}

function formatNetworkNames(networks: string[]) {
  return Array.from(new Set(networks.filter(Boolean)))
    .sort((networkA, networkB) => {
      const indexA = SPIKO_NETWORK_ORDER.indexOf(networkA);
      const indexB = SPIKO_NETWORK_ORDER.indexOf(networkB);

      if (indexA === -1 && indexB === -1) {
        return networkA.localeCompare(networkB);
      }

      if (indexA === -1) {
        return 1;
      }

      if (indexB === -1) {
        return -1;
      }

      return indexA - indexB;
    })
    .join(", ");
}

async function fetchSpikoStats(): Promise<SpikoStats> {
  try {
    const shareClasses = await getJson<ShareClass[]>(`${SPIKO_PUBLIC_API}/share-classes/`);
    const totals = await Promise.allSettled(
      shareClasses.map(async (shareClass) => ({
        shareClass,
        totals: await getJson<ShareClassTotals>(
          `${SPIKO_PUBLIC_API}/share-classes/${encodeURIComponent(shareClass.symbol)}/totals`,
        ),
      })),
    );
    const rows = totals
      .flatMap((result) => (result.status === "fulfilled" ? [result.value] : []))
      .filter(({ totals }) => Number(totals.totalAssets.value) > 0);

    if (rows.length === 0) {
      return fallbackSpikoStats;
    }

    const rates = new Map<string, number>([["EUR", 1]]);
    const currencies = Array.from(
      new Set(
        rows.flatMap(({ totals }) => [totals.totalAssets.currency, totals.totalOrders.currency]),
      ),
    );

    await Promise.all(
      currencies
        .filter((currency) => currency !== "EUR")
        .map(async (currency) => {
          const row = rows.find(
            ({ totals }) =>
              totals.totalAssets.currency === currency || totals.totalOrders.currency === currency,
          );

          if (!row) {
            return;
          }

          const rate = await getJson<ExchangeRate>(
            `${SPIKO_PUBLIC_API}/exchange-rates/latest?fundId=${encodeURIComponent(
              row.shareClass.fundId,
            )}&baseCurrency=${currency}&quoteCurrency=EUR&fallbackToAnyOtherFund=true`,
          );
          rates.set(currency, Number(rate.fxRate));
        }),
    );

    const totalAssetsInEur = rows.reduce((sum, { totals }) => {
      const rate = rates.get(totals.totalAssets.currency);

      if (!rate) {
        return sum;
      }

      return sum + Number(totals.totalAssets.value) * rate;
    }, 0);
    const totalOrdersInEur = rows.reduce((sum, { totals }) => {
      const rate = rates.get(totals.totalOrders.currency);

      if (!rate) {
        return sum;
      }

      return sum + Number(totals.totalOrders.value) * rate;
    }, 0);
    const latestUpdate = rows
      .map(({ totals }) => totals.netAssetValue?.updatedAt)
      .filter((value): value is string => Boolean(value))
      .sort()
      .at(-1);
    const networksDetail = formatNetworkNames(
      shareClasses
        .flatMap((shareClass) => shareClass.tokens?.map(({ network }) => network) ?? [])
        .concat("Solana"),
    );

    if (!Number.isFinite(totalAssetsInEur) || totalAssetsInEur <= 0) {
      return fallbackSpikoStats;
    }

    return {
      assetsLabel: formatLargeEurAmount(totalAssetsInEur),
      ordersLabel:
        Number.isFinite(totalOrdersInEur) && totalOrdersInEur > 0
          ? formatLargeEurAmount(totalOrdersInEur)
          : fallbackSpikoStats.ordersLabel,
      networksDetail: networksDetail || fallbackSpikoStats.networksDetail,
      updatedLabel: formatUpdatedAt(latestUpdate),
      isLive: true,
    };
  } catch {
    return fallbackSpikoStats;
  }
}

const spikoStats = await fetchSpikoStats();

